# ─────────────────────────────────────────────
# GOVI NETHA - Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to GitHub
# ─────────────────────────────────────────────

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/govi_netha?retryWrites=true&w=majority
MONGODB_DB_NAME=govi_netha

# Backend
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change_this_to_a_random_secret

# Frontend (Vite needs VITE_ prefix)
VITE_API_BASE_URL=http://localhost:8000/api

# ESP32 (put these in edge/src/config.h instead)
# WIFI_SSID=your_wifi
# WIFI_PASSWORD=your_password
# API_URL=http://YOUR_PC_LOCAL_IP:8000/api/sensors/data
