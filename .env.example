MONGODB_URI=mongodb://GoviNetha:govinetha%402026@ac-cuxvwq9-shard-00-00.pu3yicg.mongodb.net:27017,ac-cuxvwq9-shard-00-01.pu3yicg.mongodb.net:27017,ac-cuxvwq9-shard-00-02.pu3yicg.mongodb.net:27017/govi_netha?ssl=true&replicaSet=atlas-11tbj7-shard-0&authSource=admin&appName=Cluster0
