# ─────────────────────────────────────────────
# GOVI NETHA - Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to GitHub
# ─────────────────────────────────────────────

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB_NAME=govi_netha

# Backend
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=

# Frontend (Vite needs VITE_ prefix)
VITE_API_BASE_URL=http://localhost:8000/api

# ESP32 (put these in edge/src/config.h instead)
# WIFI_SSID=
# WIFI_PASSWORD=
# API_URL=http://YOUR_PC_LOCAL_IP:8000/api/sensors/data
